  "keywords": [
    "pi-package",
    "pi-extension",
    "cursor",
    "tmux",
    "cmux",
    "herdr",
    "focus",
    "tui",
    "truecolor",
    "ghostty"
  ],
  "license": "MIT",
  "author": "RECTOR <rector@rectorspace.com>",
  "homepage": "https://github.com/getpipher/cursor",
  "repository": {
    "type": "git",
    "url": "https://github.com/getpipher/cursor.git"
  },
  "bugs": {
    "url": "https://github.com/getpipher/cursor/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "pi": {
    "extensions": [
      "./extensions/cursor.ts"
    ]
  },
  "files": [
    "extensions",
    "lib",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
